generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  CASHIER
  BUSINESS_ADMIN
  BUSINESS_OWNER
  MICLUB_ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum BackupType {
  AUTOMATIC          @map("automatic")
  MANUAL             @map("manual")
  SCHEDULED          @map("scheduled")
  PRE_DEPLOY         @map("pre_deploy")
  PRE_MIGRATION      @map("pre_migration")
  PRE_RESTORE        @map("pre_restore")
  PRE_DATA_CLEANUP   @map("pre_data_cleanup")
  SIMULATION         @map("simulation")
}

enum BackupStatus {
  REQUESTED   @map("requested")
  RUNNING     @map("running")
  VERIFIED    @map("verified")
  FAILED      @map("failed")
  EXPIRED     @map("expired")
}

enum RestoreStatus {
  REQUESTED   @map("requested")
  VALIDATING   @map("validating")
  VALIDATED    @map("validated")
  FAILED       @map("failed")
  BLOCKED      @map("blocked")
}

enum RollbackStatus {
  PLANNED     @map("planned")
  VALIDATED   @map("validated")
  BLOCKED     @map("blocked")
  COMPLETED   @map("completed")
  FAILED      @map("failed")
}

model User {
  id                    String             @id @default(cuid())
  name                  String
  email                 String             @unique
  phone                 String
  passwordHash          String             @map("password_hash")
  birthDate             DateTime?          @map("birth_date") @db.Date
  rut                   String?            @unique
  role                  UserRole           @default(CUSTOMER)
  status                UserStatus         @default(ACTIVE)
  forcePasswordChange   Boolean            @default(false) @map("force_password_change")
  failedLoginAttempts   Int                @default(0) @map("failed_login_attempts")
  lockedAt              DateTime?          @map("locked_at")
  deletedAt             DateTime?          @map("deleted_at")
  deletedByUserId       String?             @map("deleted_by_user_id")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  sessions              AuthSession[]
  passwordResetTokens   PasswordResetToken[]
  ownedBusinesses       Business[]         @relation("BusinessOwner")
  businessMemberships   BusinessUser[]
  customerBusinesses    CustomerBusiness[]
  cycles                Cycle[]
  customerTransactions  Transaction[]      @relation("TransactionCustomer")
  performedTransactions Transaction[]      @relation("TransactionPerformer")
  cancelledTransactions Transaction[]      @relation("TransactionCanceller")
  rewards               Reward[]           @relation("RewardCustomer")
  redeemedRewards       Reward[]           @relation("RewardRedeemer")
  auditLogs             AuditLog[]
  manualCustomerMovements ManualCustomerMovement[]
  changeHistory         UserChange[]       @relation("ChangedUser")
  changesPerformed      UserChange[]       @relation("ChangeActor")
  deletedBy             User?              @relation("UserDeletion", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  usersDeleted          User[]              @relation("UserDeletion")
  supportNotesAuthored  SupportNote[]       @relation("SupportNoteAuthor")
  supportNotesSubject   SupportNote[]       @relation("SupportNoteSubject")
  impersonationsStarted ImpersonationSession[] @relation("ImpersonationActor")
  impersonationsViewed  ImpersonationSession[] @relation("ImpersonationTarget")
  manualAdjustmentsMade ManualAdjustment[]  @relation("ManualAdjustmentActor")
  manualAdjustmentsFor  ManualAdjustment[]  @relation("ManualAdjustmentCustomer")

  @@index([status])
  @@index([deletedByUserId])

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @map("token_hash")
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model UserChange {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  actorId   String   @map("actor_id")
  field     String
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  action    String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation("ChangedUser", fields: [userId], references: [id], onDelete: Cascade)
  actor     User     @relation("ChangeActor", fields: [actorId], references: [id])

  @@index([userId, createdAt])
  @@map("user_changes")
}

model AuthSession {
  id               String    @id @default(cuid())
  refreshTokenHash String    @map("refresh_token_hash")
  familyId         String    @default(cuid()) @map("family_id")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  revokedReason    String?   @map("revoked_reason")
  lastUsedAt       DateTime? @map("last_used_at")
  userAgent        String?   @map("user_agent")
  ipHash           String?   @map("ip_hash")
  deviceLabel      String?   @map("device_label")
  reuseDetectedAt  DateTime? @map("reuse_detected_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  userId           String    @map("user_id")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([userId, revokedAt, expiresAt])
  @@map("auth_sessions")
}

model RateLimitBucket {
  id        String   @id @default(cuid())
  key       String   @unique
  scope     String
  subject   String
  count     Int      @default(0)
  resetAt   DateTime @map("reset_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([scope, resetAt])
  @@map("rate_limit_buckets")
}

enum BusinessStatus {
  ACTIVE       @map("active")
  SUSPENDED    @map("suspended")
  GRACE_PERIOD @map("grace_period")
  CANCELLED    @map("cancelled")
  DELETED      @map("deleted")
}

enum MembershipStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")
}

enum ProgramStatus {
  DRAFT    @map("draft")
  ACTIVE   @map("active")
  ARCHIVED @map("archived")
}

enum AccumulationType {
  PURCHASE_COUNT @map("purchase_count")
  VISIT_COUNT    @map("visit_count")
  AMOUNT_SPENT   @map("amount_spent")
  POINTS         @map("points")
}

enum CycleStatus {
  ACTIVE    @map("active")
  COMPLETED @map("completed")
  CANCELLED @map("cancelled")
}

enum TransactionType {
  PURCHASE      @map("purchase")
  VISIT         @map("visit")
  MANUAL_POINTS @map("manual_points")
  AMOUNT        @map("amount")
}

enum TransactionStatus {
  VALID     @map("valid")
  CANCELLED @map("cancelled")
}

enum RewardStatus {
  AVAILABLE @map("available")
  REDEEMED  @map("redeemed")
  EXPIRED   @map("expired")
  CANCELLED @map("cancelled")
}

enum ManualCustomerSegment {
  GENERAL      @map("general")
  SENIOR       @map("senior")
}

enum ManualRegistrationReason {
  SENIOR        @map("senior")
  NO_SMARTPHONE @map("no_smartphone")
  NO_INTERNET   @map("no_internet")
  PREFERRED     @map("preferred")
  OTHER         @map("other")
}

enum ManualMovementType {
  STAMP            @map("stamp")
  PURCHASE         @map("purchase")
  POINTS           @map("points")
  BENEFIT_REDEEMED @map("benefit_redeemed")
}

enum BillingPeriod {
  MONTHLY @map("monthly")
  YEARLY  @map("yearly")
}

enum PlanStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")
}

enum SubscriptionStatus {
  TRIALING  @map("trialing")
  ACTIVE    @map("active")
  PAST_DUE  @map("past_due")
  SUSPENDED @map("suspended")
  CANCELLED @map("cancelled")
  EXPIRED   @map("expired")
}

enum PaymentStatus {
  PENDING   @map("pending")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")
  CANCELLED @map("cancelled")
  REFUNDED  @map("refunded")
  FAILED    @map("failed")
}

enum PaymentProvider {
  MANUAL         @map("manual")
  MERCADO_PAGO  @map("mercado_pago")
  FLOW          @map("flow")
}

enum WebhookEventStatus {
  RECEIVED  @map("received")
  PROCESSED @map("processed")
  IGNORED   @map("ignored")
  FAILED    @map("failed")
}

enum IncidentSeverity {
  CRITICAL @map("critical")
  HIGH     @map("high")
  MEDIUM   @map("medium")
}

enum IncidentStatus {
  DETECTED      @map("detected")
  INVESTIGATING @map("investigating")
  IDENTIFIED    @map("identified")
  MONITORING    @map("monitoring")
  RESOLVED      @map("resolved")
}

enum IncidentActionType {
  DETECTED          @map("detected")
  STATUS_CHANGED    @map("status_changed")
  NOTE_ADDED        @map("note_added")
  ALERT_SENT        @map("alert_sent")
  ALERT_SUPPRESSED  @map("alert_suppressed")
  RECOVERY_DETECTED @map("recovery_detected")
  RESOLVED          @map("resolved")
}

enum IncidentAlertChannel {
  EMAIL    @map("email")
  SLACK    @map("slack")
  WHATSAPP @map("whatsapp")
}

enum AuditResult {
  SUCCESS @map("success")
  FAILURE @map("failure")
  DENIED  @map("denied")
  PARTIAL @map("partial")
}

enum AuditRiskLevel {
  LOW      @map("low")
  MEDIUM   @map("medium")
  HIGH     @map("high")
  CRITICAL @map("critical")
}

enum SystemErrorStatus {
  OPEN          @map("open")
  INVESTIGATING @map("investigating")
  RESOLVED      @map("resolved")
}

model Plan {
  id                String     @id @default(cuid())
  name              String     @unique
  monthlyPrice      Decimal    @default(0) @map("monthly_price") @db.Decimal(12, 2)
  currency          String     @default("CLP")
  billingPeriod     BillingPeriod @default(MONTHLY) @map("billing_period")
  trialDays         Int        @default(0) @map("trial_days")
  customerLimit     Int        @default(500) @map("customer_limit")
  collaboratorLimit Int        @default(3) @map("collaborator_limit")
  features          Json       @default("[]")
  active            Boolean    @default(true)
  status            PlanStatus @default(ACTIVE)
  businesses        Business[]
  subscriptions     BusinessSubscription[]
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  @@map("plans")
}

model Business {
  id           String             @id @default(cuid())
  name         String
  slug         String             @unique
  businessType String             @map("business_type")
  rutBusiness  String?            @unique @map("rut_business")
  ownerUserId  String             @map("owner_user_id")
  phone        String
  email        String
  address      String
  region       String?
  commune      String?
  logoUrl      String?            @map("logo_url")
  status       BusinessStatus     @default(ACTIVE)
  planId       String?            @map("plan_id")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  owner        User               @relation("BusinessOwner", fields: [ownerUserId], references: [id])
  plan         Plan?              @relation(fields: [planId], references: [id])
  users        BusinessUser[]
  programs     LoyaltyProgram[]
  customers    CustomerBusiness[]
  cycles       Cycle[]
  transactions Transaction[]
  rewards      Reward[]
  auditLogs    AuditLog[]
  manualCustomers ManualCustomer[]
  planHistory   MerchantPlanHistory[]
  manualAdjustments ManualAdjustment[]
  subscription BusinessSubscription?
  payments BillingPayment[]

  @@map("businesses")
}

model SystemSetting {
  key         String   @id
  value       Json
  updatedById String?  @map("updated_by_id")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

enum LeadStatus {
  NEW       @map("new")
  CONTACTED @map("contacted")
  CLOSED    @map("closed")
  DISCARDED @map("discarded")
}

model CommercialLead {
  id        String     @id @default(cuid())
  name      String
  phone     String
  email     String
  business  String
  industry  String
  message   String
  source    String     @default("landing")
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([email])
  @@map("commercial_leads")
}

model SupportNote {
  id            String   @id @default(cuid())
  subjectUserId String   @map("subject_user_id")
  authorUserId  String   @map("author_user_id")
  note          String
  createdAt     DateTime @default(now()) @map("created_at")
  subject       User     @relation("SupportNoteSubject", fields: [subjectUserId], references: [id], onDelete: Cascade)
  author        User     @relation("SupportNoteAuthor", fields: [authorUserId], references: [id])

  @@index([subjectUserId, createdAt])
  @@map("support_notes")
}

model ImpersonationSession {
  id           String   @id @default(cuid())
  actorUserId  String   @map("actor_user_id")
  targetUserId String   @map("target_user_id")
  targetRole   UserRole @map("target_role")
  reason       String
  startedAt    DateTime @default(now()) @map("started_at")
  endedAt      DateTime? @map("ended_at")
  actor        User     @relation("ImpersonationActor", fields: [actorUserId], references: [id])
  target       User     @relation("ImpersonationTarget", fields: [targetUserId], references: [id])

  @@index([actorUserId, startedAt])
  @@index([targetUserId, startedAt])
  @@map("impersonation_sessions")
}

model ManualAdjustment {
  id             String   @id @default(cuid())
  customerUserId String   @map("customer_user_id")
  businessId     String   @map("business_id")
  actorUserId    String   @map("actor_user_id")
  type           String
  value          Decimal  @db.Decimal(14, 2)
  reason         String
  createdAt      DateTime @default(now()) @map("created_at")
  customer       User     @relation("ManualAdjustmentCustomer", fields: [customerUserId], references: [id])
  actor          User     @relation("ManualAdjustmentActor", fields: [actorUserId], references: [id])
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([customerUserId, businessId, createdAt])
  @@map("manual_adjustments")
}

model MerchantPlanHistory {
  id          String   @id @default(cuid())
  businessId  String   @map("business_id")
  oldPlanId   String?  @map("old_plan_id")
  newPlanId   String?  @map("new_plan_id")
  actorUserId String   @map("actor_user_id")
  reason      String?
  createdAt   DateTime @default(now()) @map("created_at")
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@map("merchant_plan_history")
}

model BusinessSubscription {
  id                    String             @id @default(cuid())
  businessId            String             @unique @map("business_id")
  planId                String             @map("plan_id")
  status                SubscriptionStatus @default(TRIALING)
  startedAt             DateTime           @default(now()) @map("started_at")
  trialEndsAt           DateTime?          @map("trial_ends_at")
  currentPeriodStartsAt DateTime           @default(now()) @map("current_period_starts_at")
  currentPeriodEndsAt   DateTime?          @map("current_period_ends_at")
  nextBillingAt         DateTime?          @map("next_billing_at")
  graceEndsAt           DateTime?          @map("grace_ends_at")
  cancelledAt           DateTime?          @map("cancelled_at")
  cancellationReason    String?            @map("cancellation_reason")
  externalProvider      PaymentProvider?   @map("external_provider")
  externalSubscriptionId String?           @unique @map("external_subscription_id")
  lastPaymentStatus     PaymentStatus?     @map("last_payment_status")
  metadata              Json?
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  business              Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan                  Plan               @relation(fields: [planId], references: [id])
  payments              BillingPayment[]

  @@index([status, nextBillingAt])
  @@index([planId])
  @@map("business_subscriptions")
}

model BillingPayment {
  id                String          @id @default(cuid())
  providerPaymentId String?         @unique @map("provider_payment_id")
  provider          PaymentProvider @default(MANUAL)
  businessId        String          @map("business_id")
  subscriptionId    String?         @map("subscription_id")
  amount            Decimal         @db.Decimal(12, 2)
  currency          String          @default("CLP")
  status            PaymentStatus   @default(PENDING)
  paidAt            DateTime?       @map("paid_at")
  periodStart       DateTime?       @map("period_start")
  periodEnd         DateTime?       @map("period_end")
  paymentMethod     String?         @map("payment_method")
  reference         String?
  idempotencyKey    String?         @unique @map("idempotency_key")
  providerPayload   Json?           @map("provider_payload")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  business          Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  subscription      BusinessSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  history           BillingPaymentHistory[]

  @@index([businessId, status, createdAt])
  @@index([subscriptionId])
  @@map("billing_payments")
}

model BillingPaymentHistory {
  id          String        @id @default(cuid())
  paymentId   String        @map("payment_id")
  oldStatus   PaymentStatus? @map("old_status")
  newStatus   PaymentStatus  @map("new_status")
  reason      String?
  metadata    Json?
  createdAt   DateTime      @default(now()) @map("created_at")
  payment     BillingPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@map("billing_payment_history")
}

model BillingWebhookEvent {
  id             String             @id @default(cuid())
  provider       PaymentProvider
  eventId        String             @map("event_id")
  eventType      String             @map("event_type")
  status         WebhookEventStatus @default(RECEIVED)
  signatureValid Boolean            @default(false) @map("signature_valid")
  payload        Json
  processedAt    DateTime?          @map("processed_at")
  error          String?
  createdAt      DateTime           @default(now()) @map("created_at")

  @@unique([provider, eventId])
  @@index([status, createdAt])
  @@map("billing_webhook_events")
}

model Incident {
  id                  String           @id @default(cuid())
  dedupeKey           String           @map("dedupe_key")
  title               String
  service             String
  environment         String
  severity            IncidentSeverity
  status              IncidentStatus   @default(DETECTED)
  startedAt           DateTime         @default(now()) @map("started_at")
  detectedAt          DateTime         @default(now()) @map("detected_at")
  recoveredAt         DateTime?        @map("recovered_at")
  closedAt            DateTime?        @map("closed_at")
  durationSeconds     Int?             @map("duration_seconds")
  deployedVersion     String?          @map("deployed_version")
  commit              String?
  summary             String
  technicalDetail     String?          @map("technical_detail")
  source              String           @default("monitor")
  responsible         String?
  finalStatus         String?          @map("final_status")
  lastAlertAt         DateTime?        @map("last_alert_at")
  alertCooldownUntil  DateTime?        @map("alert_cooldown_until")
  metadata            Json?
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  actions             IncidentAction[]
  alerts              IncidentAlert[]

  @@index([environment, status, severity, createdAt])
  @@index([service, environment, status])
  @@index([dedupeKey, environment, status])
  @@map("incidents")
}

model IncidentAction {
  id          String             @id @default(cuid())
  incidentId  String             @map("incident_id")
  actorUserId String?            @map("actor_user_id")
  action      IncidentActionType
  note        String?
  metadata    Json?
  createdAt   DateTime           @default(now()) @map("created_at")
  incident    Incident           @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("incident_actions")
}

model IncidentAlert {
  id          String               @id @default(cuid())
  incidentId  String               @map("incident_id")
  channel     IncidentAlertChannel
  status      String
  recipient   String?
  message     String?
  providerId  String?              @map("provider_id")
  sentAt      DateTime?            @map("sent_at")
  createdAt   DateTime             @default(now()) @map("created_at")
  incident    Incident             @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, channel, createdAt])
  @@map("incident_alerts")
}

model SystemError {
  id              String            @id @default(cuid())
  fingerprint     String
  environment     String
  service         String            @default("api")
  module          String?
  type            String
  message         String
  sanitizedStack  String?           @map("sanitized_stack")
  endpoint        String?
  method          String?
  statusCode      Int?              @map("status_code")
  firstSeenAt     DateTime          @default(now()) @map("first_seen_at")
  lastSeenAt      DateTime          @default(now()) @map("last_seen_at")
  occurrenceCount Int               @default(1) @map("occurrence_count")
  requestId       String?           @map("request_id")
  correlationId   String?           @map("correlation_id")
  actorUserId     String?           @map("actor_user_id")
  role            String?
  businessId      String?           @map("business_id")
  version         String?
  commit          String?
  buildNumber     String?           @map("build_number")
  status          SystemErrorStatus @default(OPEN)
  incidentId      String?           @map("incident_id")
  notes           Json?
  metadata        Json?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@unique([fingerprint, environment])
  @@index([environment, status, lastSeenAt])
  @@index([requestId])
  @@index([correlationId])
  @@index([incidentId])
  @@map("system_errors")
}

model BackupRecord {
  id              String       @id @default(cuid())
  environment     String
  databaseName    String       @map("database_name")
  version         String
  commit          String
  branch          String?
  responsibleId   String?      @map("responsible_id")
  responsibleName String?      @map("responsible_name")
  type            BackupType
  status          BackupStatus @default(REQUESTED)
  startedAt       DateTime     @default(now()) @map("started_at")
  finishedAt      DateTime?    @map("finished_at")
  durationMs      Int?         @map("duration_ms")
  sizeBytes       BigInt?      @map("size_bytes")
  checksum        String?
  result          String?
  storageProvider String       @default("provider_or_logical") @map("storage_provider")
  storageRef      String?      @map("storage_ref")
  validation      Json?
  metadata        Json?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  restores        RestoreRecord[]

  @@index([environment, status, startedAt])
  @@index([type, startedAt])
  @@map("backup_records")
}

model RestoreRecord {
  id                   String        @id @default(cuid())
  backupId             String?       @map("backup_id")
  environment          String
  targetEnvironment    String        @map("target_environment")
  temporaryDatabaseRef String?       @map("temporary_database_ref")
  requestedById        String?       @map("requested_by_id")
  requestedByName      String?       @map("requested_by_name")
  status               RestoreStatus @default(REQUESTED)
  startedAt            DateTime      @default(now()) @map("started_at")
  finishedAt           DateTime?     @map("finished_at")
  durationMs           Int?          @map("duration_ms")
  validation           Json?
  result               String?
  safetyNotes          String?       @map("safety_notes")
  metadata             Json?
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  backup               BackupRecord? @relation(fields: [backupId], references: [id], onDelete: SetNull)

  @@index([environment, status, startedAt])
  @@index([backupId])
  @@map("restore_records")
}

model RollbackPlan {
  id              String         @id @default(cuid())
  environment     String
  requestedById   String?        @map("requested_by_id")
  requestedByName String?        @map("requested_by_name")
  status          RollbackStatus @default(PLANNED)
  reason          String
  fromCommit      String?        @map("from_commit")
  toCommit        String?        @map("to_commit")
  backupId        String?        @map("backup_id")
  migrationPlan   Json?          @map("migration_plan")
  variablePlan    Json?          @map("variable_plan")
  validation      Json?
  result          String?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@index([environment, status, createdAt])
  @@map("rollback_plans")
}

model ManualCustomer {
  id                String                @id @default(cuid())
  businessId        String                @map("business_id")
  firstName         String                @map("first_name")
  lastName          String                @map("last_name")
  rut               String?
  phone             String?
  birthDate         DateTime?             @map("birth_date") @db.Date
  segment           ManualCustomerSegment @default(GENERAL)
  registrationReason ManualRegistrationReason @default(SENIOR) @map("registration_reason")
  observation       String?
  status            MembershipStatus      @default(ACTIVE)
  points            Decimal               @default(0) @db.Decimal(14, 2)
  stamps            Int                   @default(0)
  purchases         Int                   @default(0)
  programProgress   Decimal               @default(0) @map("program_progress") @db.Decimal(14, 2)
  availableBenefits Int                   @default(0) @map("available_benefits")
  redeemedBenefits  Int                   @default(0) @map("redeemed_benefits")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  business          Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  movements         ManualCustomerMovement[]

  @@unique([businessId, rut])
  @@unique([businessId, phone])
  @@index([businessId, status, segment])
  @@index([businessId, firstName, lastName])
  @@map("manual_customers")
}

model ManualCustomerMovement {
  id               String             @id @default(cuid())
  manualCustomerId String             @map("manual_customer_id")
  businessId       String             @map("business_id")
  performedByUserId String            @map("performed_by_user_id")
  type             ManualMovementType
  value            Decimal            @default(1) @db.Decimal(14, 2)
  note             String?
  createdAt        DateTime           @default(now()) @map("created_at")
  manualCustomer   ManualCustomer     @relation(fields: [manualCustomerId], references: [id], onDelete: Cascade)
  performedBy      User               @relation(fields: [performedByUserId], references: [id])

  @@index([manualCustomerId, createdAt])
  @@index([businessId, createdAt])
  @@map("manual_customer_movements")
}

model BusinessUser {
  id         String           @id @default(cuid())
  businessId String           @map("business_id")
  userId     String           @map("user_id")
  role       UserRole
  status     MembershipStatus @default(ACTIVE)
  createdAt  DateTime         @default(now()) @map("created_at")
  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([userId])
  @@map("business_users")
}

model LoyaltyProgram {
  id                   String           @id @default(cuid())
  businessId           String           @map("business_id")
  name                 String
  accumulationType     AccumulationType @map("accumulation_type")
  targetValue          Decimal          @map("target_value") @db.Decimal(14, 2)
  rewardDescription    String           @map("reward_description")
  rewardExpirationDays Int?             @map("reward_expiration_days")
  version              Int              @default(1)
  status               ProgramStatus    @default(DRAFT)
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  business             Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  cycles               Cycle[]

  @@unique([businessId, version])
  @@index([businessId, status])
  @@map("loyalty_programs")
}

model CustomerBusiness {
  id             String           @id @default(cuid())
  customerUserId String           @map("customer_user_id")
  businessId     String           @map("business_id")
  joinedAt       DateTime         @default(now()) @map("joined_at")
  status         MembershipStatus @default(ACTIVE)
  customer       User             @relation(fields: [customerUserId], references: [id], onDelete: Cascade)
  business       Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([customerUserId, businessId])
  @@index([businessId])
  @@map("customer_businesses")
}

model Cycle {
  id               String         @id @default(cuid())
  customerUserId   String         @map("customer_user_id")
  businessId       String         @map("business_id")
  loyaltyProgramId String         @map("loyalty_program_id")
  currentValue     Decimal        @default(0) @map("current_value") @db.Decimal(14, 2)
  targetValue      Decimal        @map("target_value") @db.Decimal(14, 2)
  status           CycleStatus    @default(ACTIVE)
  startedAt        DateTime       @default(now()) @map("started_at")
  completedAt      DateTime?      @map("completed_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  customer         User           @relation(fields: [customerUserId], references: [id])
  business         Business       @relation(fields: [businessId], references: [id])
  loyaltyProgram   LoyaltyProgram @relation(fields: [loyaltyProgramId], references: [id])
  transactions     Transaction[]
  rewards          Reward[]

  @@index([customerUserId, businessId, status])
  @@map("cycles")
}

model Transaction {
  id                String            @id @default(cuid())
  cycleId           String            @map("cycle_id")
  businessId        String            @map("business_id")
  customerUserId    String            @map("customer_user_id")
  performedByUserId String            @map("performed_by_user_id")
  transactionType   TransactionType   @map("transaction_type")
  previousValue     Decimal           @map("previous_value") @db.Decimal(14, 2)
  valueAdded        Decimal           @map("value_added") @db.Decimal(14, 2)
  amountOptional    Decimal?          @map("amount_optional") @db.Decimal(14, 2)
  status            TransactionStatus @default(VALID)
  createdAt         DateTime          @default(now()) @map("created_at")
  cancelledAt       DateTime?         @map("cancelled_at")
  cancelledByUserId String?           @map("cancelled_by_user_id")
  cycle             Cycle             @relation(fields: [cycleId], references: [id])
  business          Business          @relation(fields: [businessId], references: [id])
  customer          User              @relation("TransactionCustomer", fields: [customerUserId], references: [id])
  performedBy       User              @relation("TransactionPerformer", fields: [performedByUserId], references: [id])
  cancelledBy       User?             @relation("TransactionCanceller", fields: [cancelledByUserId], references: [id])

  @@index([customerUserId, businessId, status, createdAt])
  @@map("transactions")
}

model Reward {
  id                String       @id @default(cuid())
  cycleId           String       @map("cycle_id")
  businessId        String       @map("business_id")
  customerUserId    String       @map("customer_user_id")
  rewardDescription String       @map("reward_description")
  status            RewardStatus @default(AVAILABLE)
  generatedAt       DateTime     @default(now()) @map("generated_at")
  expiresAt         DateTime?    @map("expires_at")
  redeemedAt        DateTime?    @map("redeemed_at")
  redeemedByUserId  String?      @map("redeemed_by_user_id")
  cycle             Cycle        @relation(fields: [cycleId], references: [id])
  business          Business     @relation(fields: [businessId], references: [id])
  customer          User         @relation("RewardCustomer", fields: [customerUserId], references: [id])
  redeemedBy        User?        @relation("RewardRedeemer", fields: [redeemedByUserId], references: [id])

  @@index([customerUserId, businessId, status])
  @@map("rewards")
}

model AuditLog {
  id         String    @id @default(cuid())
  userId     String?   @map("user_id")
  businessId String?   @map("business_id")
  action     String
  entityType String    @map("entity_type")
  entityId   String    @map("entity_id")
  environment String   @default("development")
  actorRole  String?   @map("actor_role")
  category   String    @default("administration")
  module     String    @default("admin")
  result     AuditResult @default(SUCCESS)
  riskLevel  AuditRiskLevel @default(LOW) @map("risk_level")
  previousState Json?  @map("previous_state")
  nextState  Json?     @map("next_state")
  requestId  String?   @map("request_id")
  correlationId String? @map("correlation_id")
  endpoint   String?
  method     String?
  statusCode Int?      @map("status_code")
  durationMs Int?      @map("duration_ms")
  ipHash     String?   @map("ip_hash")
  userAgent  String?   @map("user_agent")
  version    String?
  commit     String?
  buildNumber String?  @map("build_number")
  metadata   Json?
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User?     @relation(fields: [userId], references: [id])
  business   Business? @relation(fields: [businessId], references: [id])

  @@index([businessId, createdAt])
  @@index([userId, createdAt])
  @@index([requestId])
  @@index([correlationId])
  @@index([environment, category, result, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}
