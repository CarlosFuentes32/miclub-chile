{
  "name": "@miclub/api",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "prisma migrate deploy --schema=../../database/prisma/schema.prisma && node dist/main.js",
    "prisma:generate": "prisma generate --schema=../../database/prisma/schema.prisma",
    "seed": "tsx --env-file-if-exists=../../.env ../../database/prisma/seed.ts",
    "test:email": "tsx ../../scripts/test-email-service.ts",
    "test:password-reset": "tsx ../../scripts/test-password-reset-flow.ts",
    "email:send-qa": "tsx ../../scripts/send-qa-email.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.0",
    "@prisma/client": "^6.19.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0"
  }
}
