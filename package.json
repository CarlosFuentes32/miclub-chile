{
  "name": "miclub-chile",
  "version": "1.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "backend/api",
    "packages/*"
  ],
  "scripts": {
    "dev:customer": "npm run dev --workspace=@miclub/customer",
    "dev:commerce": "npm run dev --workspace=@miclub/commerce",
    "dev:cashier": "npm run dev --workspace=@miclub/cashier",
    "dev:admin": "npm run dev --workspace=@miclub/admin",
    "dev:landing": "npm run dev --workspace=@miclub/landing",
    "dev:api": "npm run start:dev --workspace=@miclub/api",
    "build": "npm run build --workspaces --if-present",
    "prisma:generate": "prisma generate --schema=database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=database/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=database/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=database/prisma/schema.prisma",
    "prisma:seed": "npm run seed --workspace=@miclub/api",
    "prisma:seed:staging": "tsx --env-file-if-exists=.env.staging database/prisma/seed-staging.ts",
    "test:multi-commerce": "tsx scripts/test-multi-commerce.ts",
    "test:manual-customers": "tsx scripts/test-manual-customers.ts",
    "test:user-reactivation": "tsx scripts/test-user-reactivation.ts",
    "test:email": "tsx scripts/test-email-service.ts",
    "test:password-reset": "tsx scripts/test-password-reset-flow.ts",
    "test:billing": "tsx scripts/test-billing-model.ts",
    "test:enterprise-health": "tsx scripts/test-enterprise-health.ts",
    "test:enterprise-monitoring": "tsx scripts/test-enterprise-monitoring.ts",
    "test:enterprise-backups": "tsx scripts/test-enterprise-backups.ts",
    "test:enterprise-logs": "tsx scripts/test-enterprise-logs.ts",
    "test:enterprise-security": "tsx scripts/test-enterprise-security.ts",
    "test:enterprise-support": "tsx scripts/test-enterprise-support.ts",
    "billing:backfill": "tsx scripts/backfill-billing-subscriptions.ts",
    "audit:qa-prod": "tsx --env-file-if-exists=.env scripts/audit-production-qa-data.ts",
    "audit:qa-dry-run-cleanup": "tsx scripts/dry-run-qa-cleanup.ts",
    "test:doc-links": "node scripts/check-doc-links.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report playwright-report",
    "test:e2e:staging": "cross-env E2E_ENV=staging playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "cross-env": "^10.1.0",
    "prisma": "^6.19.0"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  }
}
