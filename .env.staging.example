NODE_ENV="staging"
ENVIRONMENT_LABEL="AMBIENTE DE PRUEBAS"
STAGING_DATABASE_CONFIRM="miclub-staging"
PORT=3000

# Base de datos exclusiva de staging. No reutilizar credenciales ni hostname de producción.
DATABASE_URL="postgresql://USER:PASSWORD@STAGING_HOST:5432/miclub_staging?sslmode=require"

# Secretos exclusivos de staging. Generar valores nuevos y distintos a producción.
JWT_SECRET="GENERAR_SECRETO_STAGING_64_CARACTERES"
JWT_REFRESH_SECRET="GENERAR_OTRO_SECRETO_STAGING_64_CARACTERES"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN_DAYS=7

# Dominios staging.
CORS_ORIGIN="https://staging.miclubchile.cl,https://staging-app.miclubchile.cl,https://staging-comercio.miclubchile.cl,https://staging-cajero.miclubchile.cl,https://staging-admin.miclubchile.cl"
FRONTEND_URL="https://staging.miclubchile.cl"
CUSTOMER_APP_URL="https://staging-app.miclubchile.cl"
APP_URL="https://staging-app.miclubchile.cl"
COMMERCE_APP_URL="https://staging-comercio.miclubchile.cl"
CASHIER_APP_URL="https://staging-cajero.miclubchile.cl"
ADMIN_APP_URL="https://staging-admin.miclubchile.cl"
API_URL="https://staging-api.miclubchile.cl/api"

# Variables Vite para los frontends de staging.
VITE_APP_ENV="staging"
VITE_ENVIRONMENT_LABEL="AMBIENTE DE PRUEBAS"
VITE_API_URL="https://staging-api.miclubchile.cl/api"
VITE_CUSTOMER_URL="https://staging-app.miclubchile.cl"
VITE_COMMERCE_URL="https://staging-comercio.miclubchile.cl"
VITE_CASHIER_URL="https://staging-cajero.miclubchile.cl"
VITE_ADMIN_URL="https://staging-admin.miclubchile.cl"
VITE_DEV_PASSWORD=""

# Email transaccional staging. Usar una API key Resend exclusiva de pruebas.
RESEND_API_KEY=""
EMAIL_FROM="MiClub Chile QA <no-reply@miclubchile.cl>"
SUPPORT_EMAIL="soporte@miclubchile.cl"
STAGING_EMAIL_ALLOWLIST="qa@miclubchile.cl,@miclubchile.cl"

# Seed QA staging. Definir manualmente en el proveedor; no reutilizar en producción.
QA_SEED_PASSWORD="DEFINIR_MANUALMENTE_EN_STAGING"
QA_ADMIN_EMAIL="qa.admin@miclubchile.cl"
QA_OWNER_EMAIL="qa.comercio@miclubchile.cl"
QA_CASHIER_EMAIL="qa.cajero@miclubchile.cl"
QA_CUSTOMER_1_EMAIL="qa.cliente1@miclubchile.cl"
QA_CUSTOMER_2_EMAIL="qa.cliente2@miclubchile.cl"
QA_BUSINESS_SLUG="qa-comercio-staging"
